# ─────────────────────────────────────────────────────────────────────────────
# Alfred Core Web (Admin / App Portal) — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── [Required] Application ────────────────────────────────────────────────────
PORT=7200
NEXT_PUBLIC_APP_URL=http://localhost:7200

# ── [Required] Backend Gateway ────────────────────────────────────────────────
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000

# ── [Required] SSO Portal URL ────────────────────────────────────────────────
NEXT_PUBLIC_SSO_URL=http://localhost:7100

# ── [Required] OAuth2 / OIDC ─────────────────────────────────────────────────
# Public client ID — baked into the JS bundle at build time
NEXT_PUBLIC_OAUTH_CLIENT_ID=core_web
# Server-only client credentials — used for token exchange (never exposed to browser)
OIDC_CLIENT_ID=core_web
OIDC_CLIENT_SECRET=<CHANGE_ME>

# ── [Required] NextAuth.js ────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:7200/api/auth
NEXTAUTH_SECRET=<RANDOM_SECRET>

# ── [Optional] Internal Gateway URL ──────────────────────────────────────────
# Server-side-only URL to reach the gateway container directly (bypasses DNS/reverse proxy).
# Useful in Docker environments. Falls back to NEXT_PUBLIC_GATEWAY_URL if not set.
# INTERNAL_GATEWAY_URL=http://alfred-gateway:8000

# ── [Optional] Base path ─────────────────────────────────────────────────────
# Set when the app is served under a sub-path (e.g. /app)
# BASEPATH=
# NEXTAUTH_BASEPATH=

# ── [Optional] SSL / Development ─────────────────────────────────────────────
# Disable TLS cert verification for self-signed certs (development only!)
# NODE_TLS_REJECT_UNAUTHORIZED=0